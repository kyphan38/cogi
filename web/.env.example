# Copy to .env.local and set your key (never commit .env.local)
# Required: single shared password for app sign-in and for POST /api/ai/* (header X-App-Api-Secret).
APP_API_SECRET=

GEMINI_API_KEY=
# Optional override (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# If migrating to Anthropic (see docs/MIGRATE_GEMINI_TO_CLAUDE.md), wire these in code first:
# ANTHROPIC_API_KEY=
# CLAUDE_MODEL=   # model id from Anthropic console
